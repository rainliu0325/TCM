        <style>
        
            :root {
                --theme-color: #4c8aff;
                --color-white: rgb(245, 245, 245);
                --color-black: rgb(10, 10, 10);
            }
            
            @keyframes shine {
                0% {
                    left: -18px;
                }
                100 {
                    left: 100px;
                }
            }
            
            body {
                margin: 0;
            }
            h1 {
                font-family: 'BBH Bogle';
            }
            
            body > nav:first-of-type::after {
                content: '';
                position: absolute;
                top: -20px;
                left: 0;
                width: 100%;
                height: 100%;
                background: transparent;
                z-index: -1;
            }
            nav a {
                position: relative;
            }
            nav a::before {
                content: '';
                background-color: white;
                width: 0;
                height: 5px;
                position: absolute;
                bottom: -4px;
                left: 0;
                opacity: 0;
                transition: 300ms;
            }
            nav a:hover::before {
                width: 100%;
                opacity: 1;
            }
            
            .page {
                background-color: var(--color-white);
                color: var(--color-black);
                padding: 4em;
                z-index: -2;
            }

            /* Login System Styles */
            .login-container {
                max-width: 500px;
                margin: 0 auto;
                background: white;
                border-radius: 32px;
                padding: 32px;
                box-shadow: 0 20px 35px -10px rgba(0,0,0,0.1);
            }
            .login-container h2 {
                font-size: 2rem;
                margin-bottom: 1rem;
            }
            .login-input {
                width: 100%;
                padding: 14px 18px;
                margin: 12px 0;
                border: 2px solid #e5e7eb;
                border-radius: 60px;
                font-size: 1rem;
                transition: 0.2s;
                background: white;
                color: #1f2937;
            }
            .login-input:focus {
                outline: none;
                border-color: var(--theme-color);
                box-shadow: 0 0 0 3px rgba(76,138,255,0.2);
            }
            .login-btn {
                width: 100%;
                background: var(--theme-color);
                color: white;
                border: none;
                padding: 14px;
                border-radius: 60px;
                font-size: 1rem;
                font-weight: 600;
                cursor: pointer;
                transition: 0.2s;
                margin-top: 10px;
            }
            .login-btn:hover {
                background: #3b7ae0;
                transform: translateY(-2px);
            }
            .toggle-auth {
                text-align: center;
                margin-top: 20px;
                color: #6b7280;
            }
            .toggle-auth a {
                color: var(--theme-color);
                cursor: pointer;
                font-weight: 600;
            }
            .dashboard-stats {
                display: flex;
                gap: 20px;
                margin: 30px 0;
                flex-wrap: wrap;
            }
            .stat-card {
                flex: 1;
                background: #f3f4f6;
                padding: 20px;
                border-radius: 28px;
                text-align: center;
            }
            .stat-value {
                font-size: 2.2rem;
                font-weight: 800;
                color: var(--theme-color);
                margin-top: 8px;
            }
            .avatar-upload {
                display: flex;
                align-items: center;
                gap: 20px;
                margin-bottom: 25px;
                flex-wrap: wrap;
            }
            .avatar-preview {
                width: 80px;
                height: 80px;
                border-radius: 50%;
                background: #e5e7eb;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                border: 3px solid var(--theme-color);
                overflow: hidden;
            }
            .avatar-preview img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }
            .toast-message {
                position: fixed;
                bottom: 30px;
                right: 30px;
                background: #10b981;
                color: white;
                padding: 12px 24px;
                border-radius: 60px;
                z-index: 1000;
                animation: fadeOut 2.5s forwards;
            }
            @keyframes fadeOut {
                0% { opacity: 1; transform: translateY(0); }
                70% { opacity: 1; }
                100% { opacity: 0; visibility: hidden; transform: translateY(20px); }
            }

            /* Mango Bank Styles */
            .mango-bank {
                background: linear-gradient(135deg, #fef3c7, #fde68a);
                border-radius: 32px;
                padding: 24px;
                margin-top: 24px;
                text-align: center;
            }
            .mango-bank h3 {
                font-size: 1.8rem;
                color: #b45309;
            }
            .mango-balance {
                font-size: 3rem;
                font-weight: 800;
                color: #ea580c;
                margin: 15px 0;
            }
            .mango-progress {
                background: #fffbeb;
                border-radius: 60px;
                height: 20px;
                overflow: hidden;
                margin: 15px 0;
            }
            .mango-progress-bar {
                background: linear-gradient(90deg, #f59e0b, #ea580c);
                width: 0%;
                height: 100%;
                transition: width 0.5s ease;
            }
            .game-card {
                background: white;
                border-radius: 24px;
                padding: 20px;
                margin: 15px 0;
                cursor: pointer;
                transition: transform 0.2s, box-shadow 0.2s;
                border: 1px solid #e5e7eb;
            }
            .game-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
            }
            .game-icon {
                font-size: 48px;
                margin-bottom: 10px;
            }
        </style>
        
        <script type='module'>
            const avatars = {
                0: "https://www.khanacademy.org/computer-programming/oceanus-seed/5788781288734720/latest.png",
                1: "https://www.khanacademy.org/computer-programming/oceanus-seedling/5920079982477312/latest.png",
                2: "https://www.khanacademy.org/computer-programming/oceanus-sapling/4623563875532800/latest.png",
                3: "https://www.khanacademy.org/computer-programming/oceanus-tree/6605014791733248/latest.png",
                4: "https://www.khanacademy.org/computer-programming/oceanus-tco-2026/5210133879963648/latest.png",
            };
            
            const members = document.getElementById('members')
            let membersList = [
                { name: "Fancy Boy", username: "fancypants2006", team: "Oceanus", level: 0 , points:0}, 
                { name: "Panther Programming", username: "@Darkblade_1", team: "Oceanus", level: 0 , points:0}, 
                { name: "MMS", username: "abcde1235", team:"Oceanus", level: 1, points:0},
                { name: "Aaryan", username: "AaryanRana", team: "Oceanus", level: 1 , points:0}, 
                { name: "Tompuchay", username: "Tompuchay", team: "Oceanus", level: 2 , points:0}, 
                {name: "cwalsh1223", username: "c0t", team: "Oceanus", level: 2, points:0},
                { name: "TDJ", username: "tdj.ka", team: "Oceanus", level: 2 , points:0}, 
                { name: "Akh", username: "Nxh6", team: "Oceanus", level: 3    , points:0}, 
                { name: "Behemoth", username: "jdavidsm", team: "Oceanus", level: 3    , points:0},
                { name: "windawine", username: "windawine", team: "Oceanus", level: 3    , points:0}, 
                { name: "Lord Fantasy", username: "LordFantasy", team: "Oceanus", level: 3   , points:0},
                { name: "CharlesMartel", username: "CharlesMartel732", team: "Oceanus", level: 3 , points:0}, 
                { name: "Griffinjiun", viceCaptain: true, username: "Lucas7Lee", team: "Oceanus", level: 3    , points:0},
                { name: "Lemon Games", username: "gaminglemonss", captain: true, team: "Oceanus", level: 4   , points:0},  
                { name: "NL", username: "tr4shc0der", team: "Oceanus", level: 4 , points:0}, 
            ];
            for (let i = 0; i < membersList.length; i ++){
                const member = membersList[i]
                if (!member.captain && !member.viceCaptain) {
                  member.override = member.level
                } else if (member.captain) {
                  member.override = 6;
                } else if (member.viceCaptain){
                  member.override = 5;
                }
            }
            membersList = membersList.sort((a, b) => b.override - a.override);
            document.getElementById("member-count").textContent = `${String(membersList.length)} members`;
            for (let i = 0; i < membersList.length; i ++){
                const card = document.createElement("div")
                const member = membersList[i]
                
                card.innerHTML = `
                <div class="flex w-full justify-center items-center">
                    <div class="text-center ${member.captain||member.viceCaptain?'bg-blue-200/30':'bg-gray-300/20'} rounded-xl p-3 cursor-pointer group transition duration-300 hover:${member.captain||member.viceCaptain?'bg-[var(--theme-color)]':'bg-gray-700/50'} flex flex-col items-center justify-center w-full">
                        <img src=${avatars[member.level]} width='80'>
                        <div class="${member.captain||member.viceCaptain?'bg-blue-300/20':'bg-gray-500/20'} p-1 rounded-lg w-full">
                            <h1 class="text-lg">${member.name}</h1>
                            <h2 class="text-md text-gray-700">@${member.username}</h2>
                        </div>
                    </div>
                </div>`;
                
                card.classList.add('member')
                card.addEventListener('click', function(){
                    window.open(`https://khanacademy.org/profile/${member.username}`)
                })
                
                members.appendChild(card)
            }
        </script>
